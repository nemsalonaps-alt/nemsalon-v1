{
  "name": "nemsalon-v1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @nemsalon/api run test",
    "test:contract": "pnpm --filter @nemsalon/api run test:contract",
    "test:perf": "pnpm --filter @nemsalon/api run test:perf",
    "test:all": "pnpm run test:sequential",
    "test:sequential": "pnpm run typecheck && pnpm run lint && pnpm run test:unit && pnpm run test:e2e:full",
    "test:parallel": "pnpm run typecheck && pnpm run lint && pnpm run test:unit & pnpm run test:e2e:full",
    "test:unit": "pnpm --filter @nemsalon/api run test",
    "test:unit:contract": "pnpm --filter @nemsalon/api run test:contract",
    "test:unit:watch": "pnpm --filter @nemsalon/api run test:watch",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test ui-smoke-tests.spec.ts",
    "test:e2e:mock": "playwright test mock-error-tests.spec.ts",
    "test:e2e:integration": "playwright test auth-errors.spec.ts booking-errors.spec.ts staff-errors.spec.ts customer-errors.spec.ts services-errors.spec.ts settings-errors.spec.ts advanced-errors.spec.ts",
    "test:e2e:full": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:ci": "pnpm run test:sequential",
    "test:preflight": "pnpm run test:e2e:smoke",
    "test:db": "pnpm --filter @nemsalon/api test db-schema-constraints",
    "test:contract": "pnpm --filter @nemsalon/api test openapi-contract",
    "test:security": "pnpm --filter @nemsalon/api test cross-tenant-security",
    "test:visual": "playwright test visual-regression.spec.ts",
    "test:accessibility": "playwright test accessibility-axe.spec.ts",
    "test:performance": "pnpm --filter @nemsalon/api test performance-tests",
    "test:schema:drift": "node scripts/schema-drift-check.mjs",
    "generate:sdk": "pnpm --filter @nemsalon/sdk run generate",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:migrate": "supabase db reset",
    "supabase:status": "supabase status",
    "dev:setup": "pnpm supabase:start && pnpm supabase:migrate && pnpm generate:sdk",
    "dev:reset": "curl -X POST http://localhost:3000/v1/dev/reset",
    "dev:api": "pnpm -C apps/api dev",
    "dev:web": "pnpm -C apps/web dev",
    "dev:mobile": "pnpm -C apps/mobile dev",
    "dev:worker": "pnpm -C apps/api worker:notifications",
    "e2e": "playwright test",
    "e2e:preflight": "node scripts/e2e-preflight.mjs",
    "e2e:local": "bash scripts/e2e-run.sh",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.46.0",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.2",
    "vitest": "^1.5.0"
  }
}
