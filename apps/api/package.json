{
  "name": "@nemsalon/api",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "worker:notifications": "tsx src/modules/notifications/worker/notifications-worker.ts",
    "worker:booking-expiry": "tsx src/modules/bookings/worker/booking-expiry-worker.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:contract": "vitest run --config vitest.config.ts -t contract",
    "test:perf": "vitest run --config vitest.config.ts -t perf",
    "lint": "eslint src"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.0.1",
    "@supabase/supabase-js": "^2.48.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "pino": "^8.21.0",
    "stripe": "^14.23.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "vitest": "^1.5.0"
  }
}
